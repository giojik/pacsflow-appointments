# App
APP_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
API_V1_STR=/api/v1

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Tenant
TENANT_SLUG=innova
TENANT_NAME=Innova Medical
PROVIDER_LABEL=ექიმი
CLIENT_LABEL=პაციენტი
REQUIRE_PERSONAL_ID=true
REQUIRE_DOB=true

# Database
DATABASE_URL=postgresql://pacsflow:pacsflow@db:5432/pacsflow_appointments

# LDAP / Active Directory
LDAP_ENABLED=false
LDAP_SERVER=ldap://dc.innova.local
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BIND_DN=CN=svc-pacsflow,OU=Services,DC=innova,DC=local
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=DC=innova,DC=local
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_ATTR_EMAIL=mail
LDAP_ATTR_FULLNAME=displayName
LDAP_DEFAULT_ROLE=viewer

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Outlook
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/outlook/callback

# SMS
SMS_PROVIDER=twilio
SMS_FROM=+995XXXXXXXXX
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Appointment code
CODE_PREFIX=PF
CODE_LENGTH=6
CODE_EXPIRES_HOURS=24

# QMS
QMS_WEBHOOK_URL=http://qms:8001/api/v1/webhooks/appointments
QMS_WEBHOOK_SECRET=change-me
